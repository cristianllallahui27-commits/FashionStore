@model FashionStore.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard Categorías";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1 text-primary"><i class="fas fa-tags me-2"></i>Dashboard Categorías</h1>
            <p class="text-muted mb-0">Resumen de categorías y prendas</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Categorias" asp-action="Index" class="btn btn-outline-primary">
                <i class="fas fa-list me-1"></i>Ver Categorías
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-home me-1"></i>Inicio
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-white bg-primary">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small text-white-50">Total Categorías</div>
                        <div class="fw-bold fs-2">@(Model?.TotalCategorias ?? 0)</div>
                    </div>
                    <i class="fas fa-tags fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-white bg-success">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small text-white-50">Total Prendas</div>
                        <div class="fw-bold fs-2">@(Model?.TotalPrendas ?? 0)</div>
                    </div>
                    <i class="fas fa-tshirt fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-white bg-info">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small text-white-50">Stock Total</div>
                        <div class="fw-bold fs-2">@(Model?.TotalStock ?? 0)</div>
                    </div>
                    <i class="fas fa-boxes fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom fw-bold">
            <i class="fas fa-chart-bar me-2 text-primary"></i>Prendas por Categoría
        </div>
        <div class="card-body">
            <canvas id="categoriasChart" style="max-height:350px;"></canvas>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const ctx = document.getElementById('categoriasChart');
    if (ctx) {
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Model?.PrendasByCategoryLabelsJson ?? "[]"),
                datasets: [{
                    label: 'Cantidad de prendas',
                    data: @Html.Raw(Model?.PrendasByCategoryDataJson ?? "[]"),
                    backgroundColor: ['#0d6efd','#198754','#dc3545','#ffc107','#6f42c1','#fd7e14','#20c997'],
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });
    }
</script>
}
