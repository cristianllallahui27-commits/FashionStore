@model FashionStore.Domain.DTOs.ClienteDTO

@{
    ViewData["Title"] = "Nuevo Cliente";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1 text-primary"><i class="fas fa-user-plus me-2"></i>Nuevo Cliente</h1>
            <p class="text-muted mb-0">Registra un nuevo cliente en el sistema</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-secondary shadow-sm">
                <i class="fas fa-arrow-left me-2"></i>Volver a la Lista
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary shadow-sm">
                <i class="fas fa-home me-2"></i>Volver a Inicio
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-8 col-lg-10 mx-auto">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom p-4">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-address-card text-success me-2"></i>Datos del Cliente</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" class="needs-validation">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="NombreCompleto" class="form-label fw-semibold">Nombre Completo <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-user text-muted"></i></span>
                                    <input asp-for="NombreCompleto" class="form-control form-control-lg bg-light border-0" placeholder="Ej. Juan Pérez" />
                                </div>
                                <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DNI" class="form-label fw-semibold">DNI / Documento <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-id-card text-muted"></i></span>
                                    <input asp-for="DNI" class="form-control form-control-lg bg-light border-0" placeholder="Ej. 12345678" />
                                </div>
                                <span asp-validation-for="DNI" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Telefono" class="form-label fw-semibold">Teléfono</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-phone text-muted"></i></span>
                                    <input asp-for="Telefono" class="form-control form-control-lg bg-light border-0" placeholder="Ej. 999 999 999" />
                                </div>
                                <span asp-validation-for="Telefono" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-semibold">Correo Electrónico</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-envelope text-muted"></i></span>
                                    <input asp-for="Email" type="email" class="form-control form-control-lg bg-light border-0" placeholder="Ej. cliente@correo.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Direccion" class="form-label fw-semibold">Dirección</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-map-marker-alt text-muted"></i></span>
                                    <input asp-for="Direccion" class="form-control form-control-lg bg-light border-0" placeholder="Ej. Av. Principal 123" />
                                </div>
                                <span asp-validation-for="Direccion" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-5 opacity-10">

                        <div class="d-flex justify-content-end gap-3">
                            <a asp-action="Index" class="btn btn-light px-4 py-2 fw-semibold">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm">
                                <i class="fas fa-save me-2"></i>Guardar Cliente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}