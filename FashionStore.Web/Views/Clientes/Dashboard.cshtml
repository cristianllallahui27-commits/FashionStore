@{
    ViewData["Title"] = "Dashboard Clientes";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<h1 class="mb-4">Dashboard Clientes</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card p-4">
            <h5>Total Clientes</h5>
            <h2>@Html.Raw(ViewData["TotalClientes"] ?? "0")</h2>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card p-4">
            <h5>Clientes Recientes</h5>
            <table class="table">
                <thead><tr><th>Nombre</th><th>DNI</th></tr></thead>
                <tbody id="recentClients"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const recent = @Html.Raw(ViewData["RecentClients"] ?? "[]");
        const tbody = document.getElementById('recentClients');
        recent.forEach(c => {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td>${c.NombreCompleto}</td><td>${c.DNI}</td>`;
            tbody.appendChild(tr);
        });
    </script>
}
