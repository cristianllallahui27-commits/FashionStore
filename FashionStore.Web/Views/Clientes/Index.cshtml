@model IEnumerable<FashionStore.Domain.DTOs.ClienteDTO>

@{
    ViewData["Title"] = "Gestión de Clientes";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<!-- Header -->
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1"><i class="fas fa-users me-2"></i>Gestión de Clientes</h1>
            <p class="text-muted mb-0">Administra tu base de clientes</p>
        </div>
        <a href="/Clientes/Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i>Nuevo Cliente
        </a>
    </div>
</div>

<!-- Búsqueda -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="fas fa-search text-primary"></i>
            </span>
            <input type="text" class="form-control border-start-0" id="searchClientes" placeholder="Buscar por nombre o email...">
        </div>
    </div>
</div>

<!-- Tabla de Clientes -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model?.Count() > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>DNI</th>
                            <th>Correo / Email</th>
                            <th>Teléfono</th>
                            <th>Dirección</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cliente in Model)
                        {
                            <tr>
                                <td class="fw-bold">
                                    <i class="fas fa-user-circle me-2 text-primary"></i>@cliente.NombreCompleto
                                </td>
                                <td>
                                    <i class="fas fa-id-card me-1 text-muted"></i>@cliente.DNI
                                </td>
                                <td>
                                    <i class="fas fa-envelope me-1 text-muted"></i>@(cliente.Email ?? "-")
                                </td>
                                <td>
                                    <i class="fas fa-phone me-1 text-muted"></i>@cliente.Telefono
                                </td>
                                <td>
                                    <i class="fas fa-map-marker-alt me-1 text-muted"></i>@cliente.Direccion
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="/Clientes/Details/@cliente.Id" class="btn btn-outline-primary" title="Ver Detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="/Clientes/Edit/@cliente.Id" class="btn btn-outline-warning" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger" title="Eliminar" onclick="confirmarEliminar('@cliente.Id', '@cliente.Nombre')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-5 text-center">
                <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                <p class="text-muted mb-3">No hay clientes registrados</p>
                <a href="/Clientes/Create" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Agregar Primer Cliente
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function confirmarEliminar(id, nombre) {
            Swal.fire({
                title: '¿Eliminar cliente?',
                text: `¿Estás seguro de que deseas eliminar a "${nombre}"?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f56565',
                cancelButtonColor: '#667eea',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/Clientes/Delete/${id}`, { method: 'DELETE' })
                        .then(() => {
                            window.utils.showSuccess('Cliente eliminado correctamente');
                            window.location.reload();
                        })
                        .catch(err => {
                            window.utils.showError('Error al eliminar el cliente');
                        });
                }
            });
        }

        // Búsqueda en tiempo real
        document.getElementById('searchClientes').addEventListener('keyup', function (e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('.table tbody tr');
            rows.forEach(row => {
                const nombre = row.querySelector('td:first-child').textContent.toLowerCase();
                const email = row.querySelector('td:nth-child(2)').textContent.toLowerCase();
                const matches = nombre.includes(searchTerm) || email.includes(searchTerm);
                row.style.display = matches ? '' : 'none';
            });
        });
    </script>
}
