@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            recargarConfiguracion();

            // Evitar propagación en inputs de archivo para prevenir bucle infinito/stack overflow
            $('input[type="file"]').on('click', function (e) {
                e.stopPropagation();
            });

            // Eventos de cambio de color
            $('.color-input').on('change', function () {
                const previewId = $(this).data('preview');
                const color = this.value;
                $('#' + previewId).css('background-color', color);
                $(this).siblings('.color-hex').val(color);
            });

            // Toggle tema oscuro
            $('#temaOscuro').on('change', function () {
                const label = $(this).is(':checked') ? 'Activado' : 'Desactivado';
                $('#temaOscuroLabel').text(label);
            });

            // Carga de archivos
            $('#logo').on('change', function () { cargarImagen('logo', this); });
            $('#favicon').on('change', function () { cargarImagen('favicon', this); });
            $('#imagenInstitucional').on('change', function () { cargarImagen('imagen_institucional', this); });
            $('#fondoLogin').on('change', function () { cargarImagen('fondo_login', this); });
            $('#fondoDashboard').on('change', function () { cargarImagen('fondo_dashboard', this); });
            $('#fondoMenu').on('change', function () { cargarImagen('fondo_menu', this); });
            $('#imagenLogin').on('change', function () { cargarImagen('imagen_login', this); });
            $('#banner').on('change', function () { cargarImagen('banner', this); });
        });

        function recargarConfiguracion() {
            $.ajax({
                url: '/api/configuracion/obtener',
                type: 'GET',
                dataType: 'json',
                success: function (response) {
                    if (response.success && response.data) {
                        const config = response.data;

                        // Llenar formulario
                        $('#nombreTienda').val(config.nombreTienda || 'FashionStore');
                        $('#colorPrimario').val(config.colorPrimario || '#667eea').trigger('change');
                        $('#colorSecundario').val(config.colorSecundario || '#764ba2').trigger('change');
                        $('#colorMenu').val(config.colorMenu || '#2c3e50').trigger('change');
                        $('#colorBotones').val(config.colorBotones || '#667eea').trigger('change');
                        $('#colorDashboard').val(config.colorDashboard || '#ecf0f1').trigger('change');
                        $('#colorFondo').val(config.colorFondo || '#f5f7fa').trigger('change');
                        $('#temaOscuro').prop('checked', config.temaOscuro).trigger('change');
                        $('#nombrePropietario').val(config.nombrePropietario || '');
                        $('#telefono').val(config.telefono || '');
                        $('#correo').val(config.correo || '');
                        $('#direccion').val(config.direccion || '');
                        $('#ciudad').val(config.ciudad || '');
                        $('#pais').val(config.pais || '');
                        $('#codigoPostal').val(config.codigoPostal || '');
                        $('#ruc').val(config.ruc || '');
                        $('#descripcion').val(config.descripcion || '');
                        $('#textoPiePagina').val(config.textoPiePagina || '');
                        $('#facebookUrl').val(config.facebookUrl || '');
                        $('#instagramUrl').val(config.instagramUrl || '');
                        $('#twitterUrl').val(config.twitterUrl || '');
                        $('#linkedinUrl').val(config.linkedinUrl || '');
                        $('#tiktokUrl').val(config.tiktokUrl || '');

                        // Vista previa de imágenes
                        if (config.rutaLogo) $('#previewLogo').html(`<img src="${config.rutaLogo}" class="imagen-preview">`);
                        if (config.rutaFavicon) $('#previewFavicon').html(`<img src="${config.rutaFavicon}" class="imagen-preview">`);
                        if (config.rutaImagenInstitucional) $('#previewImagenInstitucional').html(`<img src="${config.rutaImagenInstitucional}" class="imagen-preview">`);
                        if (config.rutaFondoLogin) $('#previewFondoLogin').html(`<img src="${config.rutaFondoLogin}" class="imagen-preview">`);
                        if (config.rutaFondoDashboard) $('#previewFondoDashboard').html(`<img src="${config.rutaFondoDashboard}" class="imagen-preview">`);
                        if (config.rutaFondoMenu) $('#previewFondoMenu').html(`<img src="${config.rutaFondoMenu}" class="imagen-preview">`);
                        if (config.rutaImagenLogin) $('#previewImagenLogin').html(`<img src="${config.rutaImagenLogin}" class="imagen-preview">`);
                        if (config.rutaBanner) $('#previewBanner').html(`<img src="${config.rutaBanner}" class="imagen-preview">`);
                    }
                },
                error: function () {
                    toastr.error('Error al cargar la configuración');
                }
            });
        }

            function cargarImagen(campo, elemento) {
                const archivo = elemento.files[0];

                if (!archivo) return;

                const formData = new FormData();
                formData.append('archivo', archivo);
                formData.append('campo', campo);

                mostrarCargando(true);

                $.ajax({
                    url: '/api/configuracion/cargar-imagen',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        if (response.success) {
                            toastr.success(response.message);
                            const preview = `<img src="${response.ruta}" class="imagen-preview">`;

                            const mapPreviews = {
                                'logo': '#previewLogo',
                                'favicon': '#previewFavicon',
                                'imagen_institucional': '#previewImagenInstitucional',
                                'fondo_login': '#previewFondoLogin',
                                'fondo_dashboard': '#previewFondoDashboard',
                                'fondo_menu': '#previewFondoMenu',
                                'imagen_login': '#previewImagenLogin',
                                'banner': '#previewBanner'
                            };

                            if (mapPreviews[campo]) {
                                $(mapPreviews[campo]).html(preview);
                            }

                            recargarConfiguracion();
                        }
                        mostrarCargando(false);
                    },
                    error: function (xhr) {
                        const response = xhr.responseJSON;
                        toastr.error(response?.message || 'Error al cargar la imagen');
                        mostrarCargando(false);
                    }
                });
            }

        function aplicarTema(nombreTema, primario, secundario, menu, botones, dashboard, fondo) {
            $('#colorPrimario').val(primario).trigger('change');
            $('#colorSecundario').val(secundario).trigger('change');
            $('#colorMenu').val(menu).trigger('change');
            $('#colorBotones').val(botones).trigger('change');
            $('#colorDashboard').val(dashboard).trigger('change');
            $('#colorFondo').val(fondo).trigger('change');

            toastr.success(`Tema "${nombreTema}" aplicado. Ahora guarda los cambios.`);

            // Marcar como activo
            $('.tema-btn').removeClass('active');
            event.currentTarget.closest('.tema-btn').classList.add('active');
        }

        function guardarConfiguracion() {
            const configuracion = {
                id: 1,
                nombreTienda: $('#nombreTienda').val(),
                colorPrimario: $('#colorPrimario').val(),
                colorSecundario: $('#colorSecundario').val(),
                colorMenu: $('#colorMenu').val(),
                colorBotones: $('#colorBotones').val(),
                colorDashboard: $('#colorDashboard').val(),
                colorFondo: $('#colorFondo').val(),
                temaSeleccionado: 'Personalizado',
                temaOscuro: $('#temaOscuro').is(':checked'),
                nombrePropietario: $('#nombrePropietario').val(),
                telefono: $('#telefono').val(),
                correo: $('#correo').val(),
                direccion: $('#direccion').val(),
                ciudad: $('#ciudad').val(),
                pais: $('#pais').val(),
                codigoPostal: $('#codigoPostal').val(),
                ruc: $('#ruc').val(),
                descripcion: $('#descripcion').val(),
                textoPiePagina: $('#textoPiePagina').val(),
                facebookUrl: $('#facebookUrl').val(),
                instagramUrl: $('#instagramUrl').val(),
                twitterUrl: $('#twitterUrl').val(),
                linkedInUrl: $('#linkedinUrl').val(),
                tikTokUrl: $('#tiktokUrl').val()
            };

            mostrarCargando(true);

            $.ajax({
                url: '/api/configuracion/actualizar',
                type: 'POST',
                data: JSON.stringify(configuracion),
                contentType: 'application/json',
                dataType: 'json',
                success: function (response) {
                    if (response.success) {
                        toastr.success(response.message);
                        setTimeout(() => {
                            location.reload();
                        }, 1500);
                    }
                    mostrarCargando(false);
                },
                error: function () {
                    toastr.error('Error al guardar la configuración');
                    mostrarCargando(false);
                }
            });
        }

        function restablecerConfiguracion() {
            Swal.fire({
                title: '¿Estás seguro?',
                text: 'Se reestablecerán TODOS los valores a la configuración predeterminada. Esta acción no se puede deshacer.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#667eea',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Sí, restablecer',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    mostrarCargando(true);

                    $.ajax({
                        url: '/api/configuracion/restablecer',
                        type: 'POST',
                        contentType: 'application/json',
                        dataType: 'json',
                        success: function (response) {
                            if (response.success) {
                                toastr.success(response.message);
                                setTimeout(() => {
                                    location.reload();
                                }, 1500);
                            }
                            mostrarCargando(false);
                        },
                        error: function () {
                            toastr.error('Error al restablecer la configuración');
                            mostrarCargando(false);
                        }
                    });
                }
            });
        }

        function mostrarCargando(mostrar) {
            if (mostrar) {
                $('#loadingSpinner').addClass('show');
            } else {
                $('#loadingSpinner').removeClass('show');
            }
        }
    </script>
}
