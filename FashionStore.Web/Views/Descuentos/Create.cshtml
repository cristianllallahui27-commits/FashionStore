@model FashionStore.Domain.Entities.DescuentoAutorizado
@{
    ViewData["Title"] = "Nuevo Descuento";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-plus-circle me-2 text-success"></i>Nuevo Descuento</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/Home/Index">Inicio</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Descuentos</a></li>
                    <li class="breadcrumb-item active">Nuevo</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card card-outline card-success shadow">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fas fa-percent me-2"></i>Datos del Descuento</h3>
                    </div>
                    <div class="card-body">
                        <form asp-action="Create">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                            <div class="mb-3">
                                <label asp-for="Nombre" class="form-label fw-bold">Nombre del Descuento</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-tag"></i></span>
                                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Descuento Empleado 10%" />
                                </div>
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Tipo" class="form-label fw-bold">Tipo de Descuento</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-calculator"></i></span>
                                    <select asp-for="Tipo" class="form-select" asp-items="Html.GetEnumSelectList<FashionStore.Domain.Entities.TipoDescuento>()">
                                    </select>
                                </div>
                                <span asp-validation-for="Tipo" class="text-danger small"></span>
                                <small class="text-muted"><strong>Porcentaje:</strong> se calcula sobre el subtotal. <strong>Monto Fijo:</strong> se resta directamente.</small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Valor" class="form-label fw-bold">Valor</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                                    <input asp-for="Valor" type="number" step="0.01" min="0.01" class="form-control" placeholder="Ej: 10 (para 10% o S/.10)" />
                                </div>
                                <span asp-validation-for="Valor" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <div class="form-check">
                                    <input asp-for="Activo" class="form-check-input" type="checkbox" />
                                    <label asp-for="Activo" class="form-check-label fw-bold">Activo (disponible en el POS)</label>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success flex-fill">
                                    <i class="fas fa-save me-1"></i> Guardar Descuento
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Cancelar
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
