@model IEnumerable<FashionStore.Domain.Entities.DescuentoAutorizado>
@{
    ViewData["Title"] = "Descuentos Autorizados";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-tags me-2 text-warning"></i>Descuentos Autorizados</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/Home/Index">Inicio</a></li>
                    <li class="breadcrumb-item active">Descuentos</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col-12">
                <a asp-action="Create" class="btn btn-success btn-sm">
                    <i class="fas fa-plus me-1"></i> Nuevo Descuento
                </a>
            </div>
        </div>

        <div class="card card-outline card-warning shadow-sm">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-percent me-2"></i>Lista de Descuentos</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Valor</th>
                            <th>Estado</th>
                            <th>Fecha Creación</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><strong>@item.Nombre</strong></td>
                                <td>
                                    @if (item.Tipo == FashionStore.Domain.Entities.TipoDescuento.Porcentaje)
                                    {
                                        <span class="badge bg-info">Porcentaje</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Monto Fijo</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Tipo == FashionStore.Domain.Entities.TipoDescuento.Porcentaje)
                                    {
                                        <span class="text-primary fw-bold">@item.Valor%</span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold">S/. @item.Valor.ToString("F2")</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check me-1"></i>Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Inactivo</span>
                                    }
                                </td>
                                <td>@item.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="fas fa-info-circle me-2"></i>No hay descuentos registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
