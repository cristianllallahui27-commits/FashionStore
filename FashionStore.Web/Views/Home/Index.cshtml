@model FashionStore.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard - FashionStore";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="mb-5">
    <div class="row">
        <div class="col-12">
            <div class="card gradient-primary text-white">
                <div class="card-body py-5">
                    <h1 class="mb-2"><i class="fas fa-chart-line me-3"></i>Dashboard</h1>
                    <p class="mb-0 text-white-50">Bienvenido a FashionStore - Panel de Control Profesional</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- KPI Cards -->
<section class="mb-5">
    <div class="row">
        <!-- Prendas Total -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 h-100 animate-fade-in-up" style="animation-delay: 0s;">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-tshirt fa-3x" style="color: #667eea;"></i>
                    </div>
                    <h3 class="mb-1">@Model.TotalPrendas</h3>
                    <p class="text-muted mb-0">
                        <i class="fas fa-shopping-bag me-1"></i>Prendas Total
                    </p>
                </div>
                <div class="card-footer bg-light border-top-0">
                    <a href="/Prendas/Index" class="text-decoration-none text-primary fw-bold">
                        Ver Prendas <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Categorías -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 h-100 animate-fade-in-up" style="animation-delay: 0.1s;">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-list fa-3x" style="color: #764ba2;"></i>
                    </div>
                    <h3 class="mb-1">@Model.TotalCategorias</h3>
                    <p class="text-muted mb-0">
                        <i class="fas fa-folder me-1"></i>Categorías
                    </p>
                </div>
                <div class="card-footer bg-light border-top-0">
                    <a href="/Categorias/Index" class="text-decoration-none text-primary fw-bold">
                        Ver Categorías <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Clientes -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 h-100 animate-fade-in-up" style="animation-delay: 0.2s;">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-users fa-3x" style="color: #48bb78;"></i>
                    </div>
                    <h3 class="mb-1">@Model.TotalClientes</h3>
                    <p class="text-muted mb-0">
                        <i class="fas fa-user-tie me-1"></i>Clientes Registrados
                    </p>
                </div>
                <div class="card-footer bg-light border-top-0">
                    <a href="/Clientes/Index" class="text-decoration-none text-primary fw-bold">
                        Ver Clientes <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Ventas Total -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 h-100 animate-fade-in-up" style="animation-delay: 0.3s;">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-chart-bar fa-3x" style="color: #ed8936;"></i>
                    </div>
                    <h3 class="mb-1">@Model.TotalVentas</h3>
                    <p class="text-muted mb-0">
                        <i class="fas fa-receipt me-1"></i>Ventas Registradas
                    </p>
                </div>
                <div class="card-footer bg-light border-top-0">
                    <a href="/Ventas/Index" class="text-decoration-none text-primary fw-bold">
                        Ver Ventas <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stock Status -->
<section class="mb-5">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-boxes me-2 text-warning"></i>Estado de Stock</h5>
                    @if (User.IsInRole("Administrador"))
                    {
                        <a href="/Prendas/Index" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-list me-1"></i>Ver todas las prendas
                        </a>
                    }
                </div>
                <div class="card-body">
                    <!-- Resumen en 3 badges -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="p-3 rounded-3 text-center @(Model?.CantidadAgotadas > 0 ? "bg-danger bg-opacity-10 border border-danger" : "bg-light")">
                                <div class="fw-bold fs-3 @(Model?.CantidadAgotadas > 0 ? "text-danger" : "text-muted")">
                                    @(Model?.CantidadAgotadas ?? 0)
                                </div>
                                <small class="text-muted"><i class="fas fa-times-circle me-1 text-danger"></i>Agotados (stock = 0)</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 rounded-3 text-center @(Model?.CantidadBajoStock > 0 ? "bg-warning bg-opacity-10 border border-warning" : "bg-light")">
                                <div class="fw-bold fs-3 @(Model?.CantidadBajoStock > 0 ? "text-warning" : "text-muted")">
                                    @(Model?.CantidadBajoStock ?? 0)
                                </div>
                                <small class="text-muted"><i class="fas fa-exclamation-triangle me-1 text-warning"></i>Bajo Stock (≤ 5 unid.)</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 rounded-3 text-center bg-success bg-opacity-10 border border-success">
                                <div class="fw-bold fs-3 text-success">@(Model?.CantidadStockNormal ?? 0)</div>
                                <small class="text-muted"><i class="fas fa-check-circle me-1 text-success"></i>Stock Normal (> 5 unid.)</small>
                            </div>
                        </div>
                    </div>

                    @if ((Model?.CantidadAgotadas ?? 0) == 0 && (Model?.CantidadBajoStock ?? 0) == 0)
                    {
                        <div class="alert alert-success mb-0">
                            <i class="fas fa-check-circle me-2"></i>
                            Todos los productos tienen stock óptimo.
                        </div>
                    }
                    else
                    {
                        <!-- Agotados -->
                        @if (Model?.PrendasAgotadas?.Count > 0)
                        {
                            <h6 class="fw-bold text-danger mb-2"><i class="fas fa-times-circle me-1"></i>Productos Agotados</h6>
                            <div class="row g-2 mb-3">
                                @foreach (var prenda in Model.PrendasAgotadas.Take(6))
                                {
                                    <div class="col-lg-6 col-md-12">
                                        <div class="alert alert-danger mb-0 py-2 d-flex align-items-center justify-content-between">
                                            <div>
                                                <strong>@prenda.Nombre</strong>
                                                <span class="badge bg-danger ms-2">AGOTADO</span>
                                                @if (!string.IsNullOrEmpty(prenda.CategoriaNombre))
                                                {
                                                    <span class="text-muted small ms-2">@prenda.CategoriaNombre</span>
                                                }
                                            </div>
                                            @if (User.IsInRole("Administrador"))
                                            {
                                                <a href="/Prendas/Edit/@prenda.Id" class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Bajo Stock -->
                        @if (Model?.PrendasAgotandose?.Count > 0)
                        {
                            <h6 class="fw-bold text-warning mb-2"><i class="fas fa-exclamation-triangle me-1"></i>Productos con Bajo Stock</h6>
                            <div class="row g-2">
                                @foreach (var prenda in Model.PrendasAgotandose.Take(6))
                                {
                                    <div class="col-lg-6 col-md-12">
                                        <div class="alert alert-warning mb-0 py-2 d-flex align-items-center justify-content-between">
                                            <div>
                                                <strong>@prenda.Nombre</strong>
                                                <span class="badge bg-warning text-dark ms-2">Stock: @prenda.Stock</span>
                                                @if (!string.IsNullOrEmpty(prenda.CategoriaNombre))
                                                {
                                                    <span class="text-muted small ms-2">@prenda.CategoriaNombre</span>
                                                }
                                            </div>
                                            @if (User.IsInRole("Administrador"))
                                            {
                                                <a href="/Prendas/Edit/@prenda.Id" class="btn btn-sm btn-outline-warning">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Prendas Destacadas -->
<section class="mb-5">
    <div class="row">
        <div class="col-12">
            <h4 class="mb-4 fw-bold"><i class="fas fa-star me-2"></i>Prendas Destacadas</h4>
        </div>
    </div>
    <div class="row">
        @if (Model?.Prendas?.Count > 0)
        {
            @foreach (var prenda in Model.Prendas.Take(6))
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100 animate-fade-in-up">
                        <div class="position-relative overflow-hidden" style="height: 250px; background: var(--light-bg);">
                            @if (!string.IsNullOrEmpty(prenda.ImagenUrl))
                            {
                                <img src="/uploads/productos/@prenda.ImagenUrl" alt="@prenda.Nombre"
                                     class="w-100 h-100" style="object-fit:cover; transition:transform 0.3s;"
                                     onerror="this.parentElement.innerHTML='<div class=\'w-100 h-100 d-flex align-items-center justify-content-center bg-light\'><i class=\'fas fa-tshirt fa-3x text-muted\'></i></div>'">
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                    <i class="fas fa-tshirt fa-3x text-muted"></i>
                                </div>
                            }
                            <div class="position-absolute top-0 end-0 m-2">
                                @if (prenda.Stock <= 0)
                                {
                                    <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Agotado</span>
                                }
                                else if (prenda.Stock <= 5)
                                {
                                    <span class="badge bg-warning"><i class="fas fa-exclamation me-1"></i>Bajo Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="fas fa-check me-1"></i>Disponible</span>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            <h6 class="card-title text-truncate">@prenda.Nombre</h6>
                            <p class="card-text small text-muted text-truncate">@prenda.Descripcion</p>
                            <div class="row mb-2">
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-palette me-1"></i>
                                        <strong>@prenda.Color</strong>
                                    </small>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-ruler me-1"></i>
                                        <strong>@prenda.Talla</strong>
                                    </small>
                                </div>
                            </div>
                            <div class="row align-items-center">
                                <div class="col-6">
                                    <h5 class="text-primary mb-0">S/. @prenda.Precio.ToString("F2")</h5>
                                </div>
                                <div class="col-6 text-end">
                                    <small class="badge bg-info">Stock: @prenda.Stock</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-light border-top-0">
                            <a href="/Prendas/Details/@prenda.Id" class="btn btn-sm btn-outline-primary w-100">
                                <i class="fas fa-eye me-1"></i>Ver Detalles
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    No hay prendas registradas. <a href="/Prendas/Create">Crear Primera Prenda</a>
                </div>
            </div>
        }
    </div>
</section>

<!-- Quick Actions -->
<section class="mb-5">
    <div class="row">
        <div class="col-12">
            <h4 class="mb-4 fw-bold"><i class="fas fa-bolt me-2"></i>Acciones Rápidas</h4>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-3 col-md-6 mb-3">
            <a href="/Prendas/Create" class="btn btn-primary btn-lg w-100 py-3">
                <i class="fas fa-plus me-2"></i>Nueva Prenda
            </a>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <a href="/Categorias/Create" class="btn btn-secondary btn-lg w-100 py-3">
                <i class="fas fa-plus me-2"></i>Nueva Categoría
            </a>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <a href="/Clientes/Create" class="btn btn-info btn-lg w-100 py-3">
                <i class="fas fa-plus me-2"></i>Nuevo Cliente
            </a>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <a href="/Ventas/Index" class="btn btn-success btn-lg w-100 py-3">
                <i class="fas fa-receipt me-2"></i>Nueva Venta
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Animación de entrada para el dashboard
        document.addEventListener('DOMContentLoaded', function () {
            const cards = document.querySelectorAll('.card');
            cards.forEach((card, index) => {
                card.style.animation = `fadeInUp 0.5s ease-out ${index * 0.1}s both`;
            });
        });
    </script>
}
