@model FashionStore.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

    body {
        background: linear-gradient(135deg, #141e30, #243b55);
        min-height: 100vh;
        color: white;
    }

    .dashboard-title {
        font-weight: bold;
        font-size: 40px;
        color: white;
    }

    .card-dashboard {
        border: none;
        border-radius: 25px;
        transition: 0.4s;
        color: white;
        overflow: hidden;
        backdrop-filter: blur(10px);
    }

        .card-dashboard:hover {
            transform: translateY(-10px) scale(1.02);
        }

    .bg-blue {
        background: linear-gradient(45deg, #0d6efd, #3d8bfd);
    }

    .bg-green {
        background: linear-gradient(45deg, #198754, #20c997);
    }

    .bg-orange {
        background: linear-gradient(45deg, #fd7e14, #ffc107);
    }

    .bg-red {
        background: linear-gradient(45deg, #dc3545, #ff6b6b);
    }

    .icon-dashboard {
        font-size: 55px;
        opacity: 0.7;
    }

    .chart-card {
        border: none;
        border-radius: 25px;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(12px);
        color: white;
    }

    .chart-title {
        font-weight: bold;
        color: white;
    }

    .btn-dashboard {
        border-radius: 15px;
        padding: 15px;
        font-size: 18px;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-dashboard:hover {
            transform: scale(1.03);
        }

</style>

<div class="container mt-4">

    <h1 class="dashboard-title mb-5">
        <i class="bi bi-speedometer2"></i>
        Fashion Store Dashboard
    </h1>

    <!-- TARJETAS -->

    <div class="row g-4">

        <div class="col-md-3">

            <div class="card card-dashboard bg-blue shadow p-4">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h5>Categorías</h5>

                        <h1>@Model.TotalCategorias</h1>

                    </div>

                    <i class="bi bi-tags icon-dashboard"></i>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card card-dashboard bg-green shadow p-4">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h5>Prendas</h5>

                        <h1>@Model.TotalPrendas</h1>

                    </div>

                    <i class="bi bi-bag icon-dashboard"></i>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card card-dashboard bg-orange shadow p-4">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h5>Clientes</h5>

                        <h1>@Model.TotalClientes</h1>

                    </div>

                    <i class="bi bi-people icon-dashboard"></i>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card card-dashboard bg-red shadow p-4">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h5>Ventas</h5>

                        <h1>@Model.TotalVentas</h1>

                    </div>

                    <i class="bi bi-cash-coin icon-dashboard"></i>

                </div>

            </div>

        </div>

    </div>

    <!-- GRAFICO + ACCESOS -->

    <div class="row mt-5 g-4">

        <!-- GRAFICO -->

        <div class="col-md-8">

            <div class="card chart-card shadow p-4">

                <h4 class="chart-title mb-4">

                    <i class="bi bi-bar-chart-line"></i>
                    Ventas Mensuales

                </h4>

                <canvas id="ventasChart"></canvas>

            </div>

        </div>

        <!-- ACCESOS -->

        <div class="col-md-4">

            <div class="card chart-card shadow p-4">

                <h4 class="chart-title mb-4">

                    <i class="bi bi-lightning-charge"></i>
                    Accesos rápidos

                </h4>

                <div class="d-grid gap-3">

                    <a asp-controller="Categorias"
                       asp-action="Dashboard"
                       class="btn btn-primary btn-dashboard">

                        <i class="bi bi-tags"></i>
                        Dashboard Categorías

                    </a>

                    <a asp-controller="Prendas"
                       asp-action="Dashboard"
                       class="btn btn-success btn-dashboard">

                        <i class="bi bi-bag"></i>
                        Dashboard Prendas

                    </a>

                    <a asp-controller="Clientes"
                       asp-action="Dashboard"
                       class="btn btn-warning btn-dashboard text-white">

                        <i class="bi bi-people"></i>
                        Dashboard Clientes

                    </a>

                    <a asp-controller="Ventas"
                       asp-action="Dashboard"
                       class="btn btn-danger btn-dashboard">

                        <i class="bi bi-cash-coin"></i>
                        Dashboard Ventas

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        (function () {

            const ventasLabels =
                @Html.Raw(Model.SalesChartLabelsJson ?? "[]");

            const ventasData =
                @Html.Raw(Model.SalesChartDataJson ?? "[]");

            const ventasCtx =
                document.getElementById('ventasChart').getContext('2d');

            new Chart(ventasCtx, {

                type: 'line',

                data: {

                    labels: ventasLabels,

                    datasets: [{

                        label: 'Ventas reales',

                        data: ventasData,

                        borderColor: '#00ffcc',

                        backgroundColor: 'rgba(0,255,204,0.15)',

                        fill: true,

                        tension: 0.4,

                        borderWidth: 4,

                        pointRadius: 5

                    }]

                },

                options: {

                    responsive: true,

                    plugins: {

                        legend: {

                            labels: {
                                color: 'white'
                            }

                        }

                    },

                    scales: {

                        x: {
                            ticks: {
                                color: 'white'
                            }
                        },

                        y: {
                            beginAtZero: true,
                            ticks: {
                                color: 'white'
                            }
                        }

                    }

                }

            });

        })();

    </script>

}
