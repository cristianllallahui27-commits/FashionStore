@model FashionStore.Domain.DTOs.PrendaDTO

@{
    ViewData["Title"] = "Nueva Prenda";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<style>

    body {
        background: linear-gradient(135deg,#141e30,#243b55);
        min-height: 100vh;
        color: white;
    }

    .glass-card {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .form-control,
    .form-select {
        background: rgba(255,255,255,0.15);
        border: none;
        color: white;
    }

        .form-control:focus,
        .form-select:focus {
            background: rgba(255,255,255,0.2);
            color: white;
            box-shadow: none;
        }

    label {
        margin-bottom: 8px;
        font-weight: bold;
    }

    .btn-custom {
        border-radius: 12px;
        padding: 10px 20px;
    }

</style>

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="glass-card shadow-lg p-5">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h1 class="mb-0 fw-bold">

                        👕 Nueva Prenda

                    </h1>

                    <a asp-controller="Home" asp-action="Index" class="btn btn-light">

                        <i class="bi bi-house"></i> Inicio

                    </a>

                </div>

                <form asp-action="Create"
                      enctype="multipart/form-data">

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label>Nombre</label>

                            <input asp-for="Nombre"
                                   class="form-control" />

                        </div>

                        <div class="col-md-6 mb-4">

                            <label>Talla</label>

                            <input asp-for="Talla"
                                   class="form-control" />

                        </div>

                    </div>

                    <div class="mb-4">

                        <label>Descripción</label>

                        <textarea asp-for="Descripcion"
                                  class="form-control"
                                  rows="3"></textarea>

                    </div>

                    <div class="row">

                        <div class="col-md-4 mb-4">

                            <label>Color</label>

                            <input asp-for="Color"
                                   class="form-control" />

                        </div>

                        <div class="col-md-4 mb-4">

                            <label>Precio</label>

                            <input asp-for="Precio"
                                   class="form-control" />

                        </div>

                        <div class="col-md-4 mb-4">

                            <label>Stock</label>

                            <input asp-for="Stock"
                                   class="form-control" />

                        </div>

                    </div>

                    <div class="mb-4">

                        <label>Categoría</label>

                        <select asp-for="CategoriaId"
                                asp-items="ViewBag.Categorias"
                                class="form-select">

                            <option value="">
                                -- Seleccione --
                            </option>

                        </select>

                    </div>

                    <div class="mb-4">

                        <label>Imagen</label>

                        <input type="file"
                               name="imagenFile"
                               class="form-control" />

                    </div>

                    <div class="d-flex justify-content-between">

                        <a asp-action="Index"
                           class="btn btn-secondary btn-custom">

                            Volver

                        </a>

                        <button type="submit"
                                class="btn btn-success btn-custom">

                            Guardar Prenda

                        </button>

                    </div>

                </form>

            </div>

        </div>


    </div>

</div>


@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
