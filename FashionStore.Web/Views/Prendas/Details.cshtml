@model FashionStore.Domain.DTOs.PrendaDTO

@{
    ViewData["Title"] = $"Detalle — {Model.Nombre}";
    Layout = "~/Pages/Shared/_Layout.cshtml";
    var colorCss = Model.Color?.ToLower() switch {
        "negro" or "black" => "#111",
        "blanco" or "white" => "#f5f5f5",
        "rojo" or "red" => "#dc3545",
        "azul" or "blue" => "#0d6efd",
        "verde" or "green" => "#198754",
        "amarillo" or "yellow" => "#ffc107",
        "naranja" or "orange" => "#fd7e14",
        "morado" or "purple" or "violeta" => "#6f42c1",
        "rosado" or "rosa" or "pink" => "#d63384",
        "gris" or "grey" or "gray" => "#6c757d",
        "marrón" or "marron" or "cafe" or "café" or "brown" => "#8B4513",
        "beige" or "crema" => "#d2b48c",
        "celeste" or "cyan" => "#0dcaf0",
        _ => "#6c757d"
    };
}

<div class="container-fluid py-4" style="max-width:900px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left"></i></a>
        <div>
            <h1 class="fw-bold mb-0 fs-3 text-primary"><i class="fas fa-tshirt me-2"></i>@Model.Nombre</h1>
            <p class="text-muted mb-0 small">Detalle completo del producto</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Imagen -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3 d-flex align-items-center justify-content-center bg-light rounded"
                     style="min-height:250px;">
                    @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                    {
                        <img src="/uploads/productos/@Model.ImagenUrl" alt="@Model.Nombre"
                             class="img-fluid rounded" style="max-height:250px;object-fit:contain;" />
                    }
                    else
                    {
                        <div class="text-center text-muted">
                            <i class="fas fa-tshirt fa-5x mb-2" style="color:@colorCss;opacity:0.6;"></i>
                            <div class="small">Sin imagen</div>
                        </div>
                    }
                </div>
                <div class="card-footer bg-white text-center">
                    @if (Model.Stock <= 0)
                    {
                        <span class="badge bg-danger fs-6"><i class="fas fa-times me-1"></i>Agotado</span>
                    }
                    else if (Model.Stock <= 5)
                    {
                        <span class="badge bg-warning text-dark fs-6"><i class="fas fa-exclamation me-1"></i>Bajo Stock (@Model.Stock unid.)</span>
                    }
                    else
                    {
                        <span class="badge bg-success fs-6"><i class="fas fa-check me-1"></i>Disponible (@Model.Stock unid.)</span>
                    }
                </div>
            </div>
        </div>

        <!-- Datos -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom fw-bold text-muted small text-uppercase">
                    <i class="fas fa-info-circle me-1"></i>Información del Producto
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="text-muted small mb-1">Nombre</div>
                            <div class="fw-bold">@Model.Nombre</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small mb-1">Categoría</div>
                            <span class="badge bg-info text-dark">@(Model.CategoriaNombre ?? "-")</span>
                        </div>
                        <div class="col-12">
                            <div class="text-muted small mb-1">Descripción</div>
                            <div>@(string.IsNullOrEmpty(Model.Descripcion) ? "—" : Model.Descripcion)</div>
                        </div>
                        <div class="col-sm-4">
                            <div class="text-muted small mb-1">Talla</div>
                            <span class="badge bg-light border text-dark fs-6">@Model.Talla</span>
                        </div>
                        <div class="col-sm-4">
                            <div class="text-muted small mb-1">Color</div>
                            <span class="badge bg-light border text-dark px-2">
                                <i class="fas fa-circle me-1" style="color:@colorCss;font-size:0.7em;"></i>@Model.Color
                            </span>
                        </div>
                        <div class="col-sm-4">
                            <div class="text-muted small mb-1">Stock</div>
                            <span class="fw-bold fs-5 @(Model.Stock <= 0 ? "text-danger" : Model.Stock <= 5 ? "text-warning" : "text-success")">
                                @Model.Stock unidades
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom fw-bold text-muted small text-uppercase">
                    <i class="fas fa-tag me-1"></i>Precio y Código
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="text-muted small mb-1">Precio de Venta</div>
                            <div class="fw-bold fs-3 text-primary">S/. @Model.Precio.ToString("F2")</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small mb-1">Código de Barras</div>
                            @if (!string.IsNullOrEmpty(Model.CodigoBarra))
                            {
                                <div>
                                    <i class="fas fa-barcode me-1 text-secondary"></i>
                                    <span class="font-monospace fw-bold">@Model.CodigoBarra</span>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">No registrado</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones (solo Admin) -->
    @if (User.IsInRole("Administrador"))
    {
        <div class="d-flex gap-2 mt-4 justify-content-end">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="fas fa-edit me-1"></i>Editar Prenda
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                <i class="fas fa-trash me-1"></i>Eliminar
            </a>
        </div>
    }
</div>
