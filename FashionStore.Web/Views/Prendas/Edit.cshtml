@model FashionStore.Domain.DTOs.PrendaDTO

<h1 class="mt-4">Editar Prenda</h1>

<hr />

<div class="row">

    <div class="col-md-6">

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion"
                          class="form-control"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Talla" class="form-label"></label>
                <input asp-for="Talla" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Color" class="form-label"></label>
                <input asp-for="Color" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Precio" class="form-label"></label>
                <input asp-for="Precio" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Stock" class="form-label"></label>
                <input asp-for="Stock" class="form-control" />
            </div>

            <div class="mb-3">

                <label class="form-label">
                    Categoría
                </label>

                <select asp-for="CategoriaId"
                        asp-items="ViewBag.Categorias"
                        class="form-select">
                </select>

            </div>

            <button type="submit"
                    class="btn btn-warning">
                Actualizar
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Volver
            </a>

        </form>

    </div>

</div>