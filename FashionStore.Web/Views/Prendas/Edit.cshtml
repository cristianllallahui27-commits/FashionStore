@model FashionStore.Domain.DTOs.PrendaDTO

@{
    ViewData["Title"] = "Editar Prenda";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1 text-primary"><i class="fas fa-edit me-2"></i>Editar Prenda</h1>
            <p class="text-muted mb-0">Modifica los detalles del producto y gestiona su catálogo</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver al Catálogo
        </a>
    </div>

    <div class="row g-4">
        <!-- FORM COLUMN (col-lg-8) -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom p-4">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-file-alt text-warning me-2"></i>Información de la Prenda</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 rounded-3 d-none"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImagenUrl" />

                        <div class="row g-4">
                            <!-- Nombre -->
                            <div class="col-md-6">
                                <label asp-for="Nombre" class="form-label fw-semibold">Nombre del Producto *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-tag text-muted"></i></span>
                                    <input asp-for="Nombre" class="form-control form-control-lg bg-light border-0" placeholder="Ej. Camiseta Polo" required />
                                </div>
                                <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Categoria -->
                            <div class="col-md-6">
                                <label asp-for="CategoriaId" class="form-label fw-semibold">Categoría *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-list text-muted"></i></span>
                                    <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" class="form-select form-select-lg bg-light border-0" required>
                                        <option value="">Seleccione una categoría</option>
                                    </select>
                                </div>
                                <span asp-validation-for="CategoriaId" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Descripcion -->
                            <div class="col-12">
                                <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
                                <textarea asp-for="Descripcion" class="form-control bg-light border-0" rows="3" placeholder="Detalles o especificaciones adicionales de la prenda..."></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Talla -->
                            <div class="col-md-3">
                                <label asp-for="Talla" class="form-label fw-semibold">Talla *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-ruler text-muted"></i></span>
                                    <input asp-for="Talla" class="form-control form-control-lg bg-light border-0" placeholder="S, M, L, XL" required />
                                </div>
                                <span asp-validation-for="Talla" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Color -->
                            <div class="col-md-3">
                                <label asp-for="Color" class="form-label fw-semibold">Color *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-palette text-muted"></i></span>
                                    <input asp-for="Color" class="form-control form-control-lg bg-light border-0" placeholder="Ej. Azul" required />
                                </div>
                                <span asp-validation-for="Color" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Precio -->
                            <div class="col-md-3">
                                <label asp-for="Precio" class="form-label fw-semibold">Precio (S/.) *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0">S/.</span>
                                    <input asp-for="Precio" type="number" step="0.01" min="0.01" class="form-control form-control-lg bg-light border-0" required />
                                </div>
                                <span asp-validation-for="Precio" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Stock -->
                            <div class="col-md-3">
                                <label asp-for="Stock" class="form-label fw-semibold">Stock *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-boxes text-muted"></i></span>
                                    <input asp-for="Stock" type="number" min="0" class="form-control form-control-lg bg-light border-0" required />
                                </div>
                                <span asp-validation-for="Stock" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- CodigoBarra -->
                            <div class="col-md-6">
                                <label asp-for="CodigoBarra" class="form-label fw-semibold">Código de Barras</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-barcode text-muted"></i></span>
                                    <input asp-for="CodigoBarra" class="form-control form-control-lg bg-light border-0" placeholder="Opcional - código para lector" />
                                </div>
                                <span asp-validation-for="CodigoBarra" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- ImagenFile Input -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Nueva Imagen del Producto</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-image text-muted"></i></span>
                                    <input type="file" name="imagenFile" id="imagenFileInput" class="form-control form-control-lg bg-light border-0" accept="image/*" />
                                </div>
                                <div class="form-text text-muted small mt-1">Sube una nueva foto para actualizar o reemplazar la anterior.</div>
                            </div>
                        </div>

                        <hr class="my-5 opacity-10">

                        <div class="d-flex justify-content-end gap-3">
                            <a asp-action="Index" class="btn btn-light btn-lg px-4 fw-semibold">Cancelar</a>
                            <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold text-dark shadow-sm">
                                <i class="fas fa-save me-2"></i>Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- IMAGE PREVIEW COLUMN (col-lg-4) -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-bottom p-4 text-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-eye text-primary me-2"></i>Visualización de Imagen</h5>
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center p-5 bg-light-subtle">
                    <div id="imagePreviewContainer" class="position-relative border border-2 border-dashed rounded-4 p-3 bg-white shadow-sm d-flex align-items-center justify-content-center overflow-hidden" style="width: 250px; height: 250px;">
                        @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                        {
                            <img id="imagePreview" src="/uploads/productos/@Model.ImagenUrl" class="img-fluid rounded-3 h-100 w-100 object-fit-cover" alt="@Model.Nombre" />
                        }
                        else
                        {
                            <div id="imagePlaceholder" class="text-center text-muted">
                                <i class="fas fa-images fa-4x mb-3 text-secondary"></i>
                                <div class="small fw-semibold">Sin imagen de producto</div>
                            </div>
                            <img id="imagePreview" src="" class="img-fluid rounded-3 h-100 w-100 object-fit-cover d-none" alt="Vista previa" />
                        }
                    </div>
                    <div class="mt-4 text-center">
                        <h6 class="fw-bold text-dark mb-1" id="productPreviewName">@(!string.IsNullOrEmpty(Model.Nombre) ? Model.Nombre : "Nombre de la Prenda")</h6>
                        <span class="text-primary fw-bold fs-5" id="productPreviewPrice">S/. @Model.Precio.ToString("F2")</span>
                        <div class="text-muted small mt-2">
                            <span>Talla: <strong id="productPreviewTalla">@Model.Talla</strong></span>
                            <span class="mx-2">|</span>
                            <span>Color: <strong id="productPreviewColor">@Model.Color</strong></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Live Preview inputs
            const nameInput = document.getElementById('Nombre');
            const priceInput = document.getElementById('Precio');
            const tallaInput = document.getElementById('Talla');
            const colorInput = document.getElementById('Color');
            const fileInput = document.getElementById('imagenFileInput');

            const previewName = document.getElementById('productPreviewName');
            const previewPrice = document.getElementById('productPreviewPrice');
            const previewTalla = document.getElementById('productPreviewTalla');
            const previewColor = document.getElementById('productPreviewColor');
            const previewImg = document.getElementById('imagePreview');
            const placeholder = document.getElementById('imagePlaceholder');

            nameInput.addEventListener('input', () => {
                previewName.textContent = nameInput.value.trim() || 'Nombre de la Prenda';
            });

            priceInput.addEventListener('input', () => {
                const val = parseFloat(priceInput.value) || 0;
                previewPrice.textContent = `S/. ${val.toFixed(2)}`;
            });

            tallaInput.addEventListener('input', () => {
                previewTalla.textContent = tallaInput.value.trim() || '-';
            });

            colorInput.addEventListener('input', () => {
                previewColor.textContent = colorInput.value.trim() || '-';
            });

            fileInput.addEventListener('change', (e) => {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = (event) => {
                        previewImg.src = event.target.result;
                        previewImg.classList.remove('d-none');
                        if (placeholder) placeholder.classList.add('d-none');
                    };
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>
}