@model IEnumerable<FashionStore.Domain.DTOs.PrendaDTO>

@{
    ViewData["Title"] = "Gestión de Prendas";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<!-- Header -->
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1"><i class="fas fa-tshirt me-2"></i>Gestión de Prendas</h1>
            <p class="text-muted mb-0">Administra tu catálogo de productos</p>
        </div>
        <a href="/Prendas/Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i>Nueva Prenda
        </a>
    </div>
</div>

<!-- Search and Filter -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="fas fa-search text-primary"></i>
            </span>
            <input type="text" class="form-control border-start-0" id="searchPrendas" placeholder="Buscar prendas por nombre...">
        </div>
    </div>
    <div class="col-md-6">
        <select class="form-select" id="filterStock">
            <option value="">Filtrar por Stock</option>
            <option value="available">Disponibles</option>
            <option value="low">Bajo Stock</option>
            <option value="out">Agotado</option>
        </select>
    </div>
</div>

<!-- Tabla de Prendas -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model?.Count() > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Cód. Barras</th>
                            <th>Categoría</th>
                            <th>Color</th>
                            <th>Talla</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Estado</th>
                            @if (User.IsInRole("Administrador"))
                            {
                                <th class="text-end">Acciones</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prenda in Model)
                        {
                            <tr>
                                <td class="fw-bold">@prenda.Nombre</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(prenda.CodigoBarra))
                                    {
                                        <span class="badge bg-secondary font-monospace">
                                            <i class="fas fa-barcode me-1"></i>@prenda.CodigoBarra
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">@(prenda.CategoriaNombre ?? "-")</span>
                                </td>
                                <td>
                                    @{
                                        /* Color legible: ícono coloreado + texto oscuro sobre fondo claro */
                                        var colorCss = prenda.Color?.ToLower() switch {
                                            "negro" or "black" => "#111",
                                            "blanco" or "white" => "#f8f9fa",
                                            "rojo" or "red" => "#dc3545",
                                            "azul" or "blue" => "#0d6efd",
                                            "verde" or "green" => "#198754",
                                            "amarillo" or "yellow" => "#ffc107",
                                            "naranja" or "orange" => "#fd7e14",
                                            "morado" or "purple" or "violeta" => "#6f42c1",
                                            "rosado" or "rosa" or "pink" => "#d63384",
                                            "gris" or "grey" or "gray" => "#6c757d",
                                            "marrón" or "marron" or "cafe" or "café" or "brown" => "#8B4513",
                                            "beige" or "crema" => "#d2b48c",
                                            "celeste" or "cyan" => "#0dcaf0",
                                            _ => "#6c757d"
                                        };
                                    }
                                    <span class="badge bg-light border text-dark px-2 py-1">
                                        <i class="fas fa-circle me-1" style="color:@colorCss; font-size:0.7em;"></i>@prenda.Color
                                    </span>
                                </td>
                                <td><span class="badge bg-light border text-dark">@prenda.Talla</span></td>
                                <td class="text-primary fw-bold">S/. @prenda.Precio.ToString("F2")</td>
                                <td>
                                    @if (prenda.Stock == 0)
                                    {
                                        <span class="badge bg-danger">0</span>
                                    }
                                    else if (prenda.Stock <= 5)
                                    {
                                        <span class="badge bg-warning text-dark">@prenda.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@prenda.Stock</span>
                                    }
                                </td>
                                <td>
                                    @if (prenda.Stock <= 0)
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Agotado</span>
                                    }
                                    else if (prenda.Stock <= 5)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="fas fa-exclamation me-1"></i>Bajo Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check me-1"></i>Disponible</span>
                                    }
                                </td>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="/Prendas/Details/@prenda.Id" class="btn btn-outline-primary" title="Detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="/Prendas/Edit/@prenda.Id" class="btn btn-outline-warning" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-outline-danger" title="Eliminar"
                                                    onclick="confirmarEliminar('@prenda.Id', '@prenda.Nombre')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-5 text-center">
                <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                <p class="text-muted mb-3">No hay prendas registradas</p>
                <a href="/Prendas/Create" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Crear Primera Prenda
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function confirmarEliminar(id, nombre) {
            Swal.fire({
                title: '¿Eliminar prenda?',
                text: `¿Estás seguro de que deseas eliminar "${nombre}"?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f56565',
                cancelButtonColor: '#667eea',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Hacer petición DELETE aquí
                    fetch(`/Prendas/Delete/${id}`, { method: 'DELETE' })
                        .then(() => {
                            window.utils.showSuccess('Prenda eliminada correctamente');
                            window.location.reload();
                        })
                        .catch(err => {
                            window.utils.showError('Error al eliminar la prenda');
                        });
                }
            });
        }

        // Búsqueda en tiempo real
        document.getElementById('searchPrendas').addEventListener('keyup', function (e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('.table tbody tr');
            rows.forEach(row => {
                const name = row.querySelector('td:first-child').textContent.toLowerCase();
                row.style.display = name.includes(searchTerm) ? '' : 'none';
            });
        });

        // Filtro de stock
        document.getElementById('filterStock').addEventListener('change', function (e) {
            const filter = e.target.value;
            const rows = document.querySelectorAll('.table tbody tr');
            rows.forEach(row => {
                let display = true;
                if (filter === 'available') {
                    display = !row.querySelector('.badge-danger') && !row.querySelector('.badge-warning');
                } else if (filter === 'low') {
                    display = !!row.querySelector('.badge-warning');
                } else if (filter === 'out') {
                    display = !!row.querySelector('.badge-danger');
                }
                row.style.display = display ? '' : 'none';
            });
        });
    </script>
}
