@model IEnumerable<FashionStore.Domain.DTOs.PrendaDTO>

@{
    ViewData["Title"] = "Prendas";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">

<style>

    body {
        background: linear-gradient(135deg,#141e30,#243b55);
        min-height: 100vh;
        color: white;
    }

    .glass-card {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .table {
        color: white;
    }

        .table thead {
            background: rgba(255,255,255,0.15);
        }

    .btn-custom {
        border-radius: 12px;
    }

    img {
        border-radius: 10px;
    }

</style>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="fw-bold">
            👕 Gestión de Prendas
        </h1>

        <div>

            <a asp-action="Dashboard"
               class="btn btn-warning btn-custom me-2">

                Dashboard

            </a>

            <a asp-action="Create"
               class="btn btn-success btn-custom">

                + Nueva Prenda

            </a>

        </div>

    </div>

    <div class="glass-card p-4 shadow-lg">

        <table class="table table-hover align-middle">

            <thead>

                <tr>

                    <th>Imagen</th>
                    <th>Nombre</th>
                    <th>Talla</th>
                    <th>Color</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Acciones</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>

                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="~/images/@item.ImagenUrl"
                                     width="70"
                                     height="70"
                                     style="object-fit:cover;" />
                            }

                        </td>

                        <td>@item.Nombre</td>

                        <td>@item.Talla</td>

                        <td>@item.Color</td>

                        <td>S/ @item.Precio</td>

                        <td>@item.Stock</td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-primary btn-sm">

                                Editar

                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm text-white">

                                Detalles

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">

                                Eliminar

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

</div>
    </div>
