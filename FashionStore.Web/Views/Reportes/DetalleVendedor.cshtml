@model List<FashionStore.Domain.Entities.Venta>

@{
    ViewData["Title"] = "Detalle Vendedor";
    Layout = "~/Pages/Shared/_Layout.cshtml";
    var vendedor = (FashionStore.Domain.Entities.Vendedor)ViewBag.Vendedor;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="fas fa-arrow-left me-1"></i>Volver
            </a>
            <h1 class="fw-bold mb-0 text-primary">@vendedor.Nombres @vendedor.Apellidos</h1>
            <p class="text-muted mb-0 small">Detalle de ventas y transacciones</p>
        </div>
        <a asp-action="PdfVendedor" asp-route-id="@vendedor.Id" class="btn btn-danger" target="_blank">
            <i class="fas fa-file-pdf me-1"></i>Descargar PDF
        </a>
    </div>

    <!-- Información del Vendedor -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title fw-bold mb-3">Información Personal</h6>
                    <p class="mb-2"><strong>DNI:</strong> @vendedor.DNI</p>
                    <p class="mb-2"><strong>Correo:</strong> @vendedor.Correo</p>
                    <p class="mb-0"><strong>Teléfono:</strong> @(vendedor.Telefono ?? "-")</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title fw-bold mb-3">Estadísticas</h6>
                    <p class="mb-2">
                        <strong>Total de Ventas:</strong> 
                        <span class="badge bg-primary">@Model.Count</span>
                    </p>
                    <p class="mb-2">
                        <strong>Monto Total:</strong> 
                        <span class="fw-bold text-success">S/. @Model.Sum(v => v.Total).ToString("F2")</span>
                    </p>
                    <p class="mb-0">
                        <strong>Productos Vendidos:</strong> 
                        <span class="badge bg-success">@Model.SelectMany(v => v.DetalleVentas ?? new List<FashionStore.Domain.Entities.DetalleVenta>()).Sum(dv => dv.Cantidad)</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Ventas -->
    @if (Model.Count > 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="fas fa-receipt me-2"></i>Detalle de Ventas
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Producto</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-end">Precio Unit.</th>
                            <th class="text-end">Subtotal</th>
                            <th>Método Pago</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var venta in Model.OrderByDescending(v => v.Fecha))
                        {
                            @foreach (var detalle in venta.DetalleVentas ?? new List<FashionStore.Domain.Entities.DetalleVenta>())
                            {
                                <tr>
                                    <td>
                                        <small class="text-muted">@venta.Fecha.ToString("dd/MM/yyyy")</small>
                                    </td>
                                    <td>
                                        <strong>@venta.Cliente?.NombreCompleto</strong>
                                    </td>
                                    <td>
                                        @detalle.Prenda?.Nombre
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info">@detalle.Cantidad</span>
                                    </td>
                                    <td class="text-end">
                                        S/. @detalle.Precio.ToString("F2")
                                    </td>
                                    <td class="text-end fw-bold text-primary">
                                        S/. @detalle.Subtotal.ToString("F2")
                                    </td>
                                    <td>
                                        <small class="badge bg-light text-dark">@venta.MetodoPago?.Nombre</small>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>Este vendedor no tiene ventas registradas.
        </div>
    }
</div>
