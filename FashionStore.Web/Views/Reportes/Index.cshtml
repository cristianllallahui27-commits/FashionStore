@{
    ViewData["Title"] = "Reportes de Ventas";
    Layout = "~/Pages/Shared/_Layout.cshtml";
    var reporteSummary = (List<dynamic>)ViewBag.ReporteSummary;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0 text-primary"><i class="fas fa-chart-bar me-2"></i>Reportes de Ventas</h1>
            <p class="text-muted mb-0 small">Análisis detallado de vendedores y transacciones</p>
        </div>
        <a asp-action="ExcelVendedores" class="btn btn-success btn-sm">
            <i class="fas fa-file-excel me-1"></i>Descargar Excel
        </a>
    </div>

    @if (reporteSummary != null && reporteSummary.Count > 0)
    {
        <div class="row g-3 mb-4">
            @foreach (var reporte in reporteSummary)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h6 class="card-title fw-bold mb-1">@reporte.Vendedor</h6>
                                    <p class="card-text text-muted small mb-0">Vendedor</p>
                                </div>
                                <a asp-action="DetalleVendedor" asp-route-id="@reporte.VendedorId" 
                                   class="btn btn-sm btn-outline-primary" title="Ver detalle">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>

                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="bg-light p-2 rounded">
                                        <small class="text-muted d-block">Ventas</small>
                                        <strong class="text-primary">@reporte.TotalVentas</strong>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light p-2 rounded">
                                        <small class="text-muted d-block">Productos</small>
                                        <strong class="text-success">@reporte.ProductosTotales</strong>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-3 pt-3 border-top">
                                <small class="text-muted">Monto Total</small>
                                <h5 class="text-primary fw-bold mb-0">S/. @reporte.MontoTotal.ToString("F2")</h5>
                            </div>

                            <a asp-action="PdfVendedor" asp-route-id="@reporte.VendedorId" 
                               class="btn btn-sm btn-outline-danger w-100 mt-3" target="_blank">
                                <i class="fas fa-file-pdf me-1"></i>Descargar PDF
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Tabla Resumen -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="fas fa-table me-2"></i>Resumen Total
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Vendedor</th>
                            <th class="text-center">Total Ventas</th>
                            <th class="text-center">Productos</th>
                            <th class="text-end">Monto Total</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reporte in reporteSummary)
                        {
                            <tr>
                                <td>
                                    <strong>@reporte.Vendedor</strong>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary">@reporte.TotalVentas</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-success">@reporte.ProductosTotales</span>
                                </td>
                                <td class="text-end">
                                    <span class="fw-bold text-primary">S/. @reporte.MontoTotal.ToString("F2")</span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="DetalleVendedor" asp-route-id="@reporte.VendedorId" 
                                       class="btn btn-sm btn-outline-info" title="Ver detalle">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="PdfVendedor" asp-route-id="@reporte.VendedorId" 
                                       class="btn btn-sm btn-outline-danger" target="_blank" title="PDF">
                                        <i class="fas fa-file-pdf"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>No hay ventas registradas aún.
        </div>
    }
</div>
