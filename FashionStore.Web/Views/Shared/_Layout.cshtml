@inject FashionStore.Web.Services.IConfiguracionSistemaService ConfigService
@{
    Layout = null;
    var config = await ConfigService.ObtenerConfiguracionAsync();
    var colorPrimario = config.ColorPrimario ?? "#667eea";
    var colorSecundario = config.ColorSecundario ?? "#764ba2";
    var colorMenu = config.ColorMenu ?? "#1a1a2e";
    var colorBotones = config.ColorBotones ?? "#667eea";
    var colorFondo = config.ColorFondo ?? "#f5f7fa";
    var temaOscuro = config.TemaOscuro;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @(config.NombreTienda ?? "FashionStore")</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet" />

    <!-- Toastr -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <!-- Custom site styles -->
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/temas.css" />

    @if (!string.IsNullOrEmpty(config.RutaFavicon))
    {
        <link rel="icon" type="image/png" href="@config.RutaFavicon" />
    }

    <!-- CSS Variables dinámicas desde Configuración del Sistema -->
    <style>
        :root {
            --fs-primary: @colorPrimario;
            --fs-secondary: @colorSecundario;
            --fs-menu-bg: @colorMenu;
            --fs-btn: @colorBotones;
            --fs-bg: @colorFondo;
            --fs-gradient: linear-gradient(135deg, @colorPrimario 0%, @colorSecundario 100%);
            --fs-gradient-nav: linear-gradient(135deg, @colorMenu 0%, @colorPrimario 100%);
        }

        * { font-family: 'Inter', sans-serif; }

        body {
            @if (!string.IsNullOrEmpty(config.RutaFondoDashboard))
            {
                <text>
                background: url('@config.RutaFondoDashboard') no-repeat center center fixed !important;
                background-size: cover !important;
                </text>
            }
            else
            {
                <text>background-color: var(--fs-bg);</text>
            }
            min-height: 100vh;
            margin: 0;
        }

        /* ===== NAVBAR PRINCIPAL ===== */
        .fs-navbar {
            background: var(--fs-gradient-nav);
            padding: 0 1.5rem;
            box-shadow: 0 2px 20px rgba(0,0,0,0.3);
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .fs-navbar .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .fs-navbar .navbar-brand img {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid rgba(255,255,255,0.4);
        }

        .fs-navbar .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            font-size: 0.875rem;
            padding: 1rem 0.875rem !important;
            transition: all 0.2s ease;
            border-bottom: 3px solid transparent;
        }

        .fs-navbar .nav-link:hover,
        .fs-navbar .nav-link.active {
            color: white !important;
            border-bottom-color: rgba(255,255,255,0.6);
            background: rgba(255,255,255,0.08);
        }

        .fs-navbar .dropdown-menu {
            border: none;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            min-width: 220px;
            padding: 0.5rem;
        }

        .fs-navbar .dropdown-item {
            border-radius: 8px;
            padding: 0.5rem 1rem;
            font-size: 0.875rem;
            transition: all 0.15s;
        }

        .fs-navbar .dropdown-item:hover {
            background: linear-gradient(135deg, rgba(102,126,234,0.08), rgba(118,75,162,0.08));
            color: var(--fs-primary);
        }

        .fs-navbar .badge-role {
            font-size: 0.7rem;
            padding: 0.2em 0.6em;
            border-radius: 20px;
        }

        /* ===== CONTENT WRAPPER ===== */
        .fs-content {
            padding: 1.5rem;
            min-height: calc(100vh - 130px);
        }

        /* ===== PAGE HEADER ===== */
        .fs-page-header {
            background: var(--fs-gradient);
            color: white;
            border-radius: 16px;
            padding: 1.5rem 2rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.12);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .fs-page-header .header-icon {
            width: 52px;
            height: 52px;
            background: rgba(255,255,255,0.2);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }

        .fs-page-header h1 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 700;
        }

        .fs-page-header .breadcrumb {
            margin: 0;
            background: none;
            padding: 0;
        }

        .fs-page-header .breadcrumb-item a { color: rgba(255,255,255,0.8); }
        .fs-page-header .breadcrumb-item.active { color: rgba(255,255,255,0.6); font-size: 0.8rem; }
        .fs-page-header .breadcrumb-item + .breadcrumb-item::before { color: rgba(255,255,255,0.5); }

        /* ===== CARDS ===== */
        .card {
            border: none !important;
            border-radius: 16px !important;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08) !important;
            transition: box-shadow 0.2s ease;
            @if (!string.IsNullOrEmpty(config.RutaFondoDashboard))
            {
                <text>
                background: rgba(255, 255, 255, 0.9) !important;
                backdrop-filter: blur(8px);
                </text>
            }
        }

        .card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.12) !important; }

        /* ===== BOTONES PRIMARIOS ===== */
        .btn-primary {
            background: var(--fs-gradient) !important;
            border: none !important;
            border-radius: 10px !important;
            font-weight: 600;
            box-shadow: 0 3px 12px rgba(102,126,234,0.4) !important;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(102,126,234,0.5) !important;
        }

        /* ===== FOOTER ===== */
        .fs-footer {
            background: @colorMenu;
            color: rgba(255,255,255,0.7);
            text-align: center;
            padding: 1rem;
            font-size: 0.8rem;
        }

        .fs-footer a { color: rgba(255,255,255,0.8); }

        /* ===== TOGGLER mobile ===== */
        .navbar-toggler { border-color: rgba(255,255,255,0.3); }
        .navbar-toggler-icon { filter: invert(1); }

        /* ===== TABLES ===== */
        .table thead th {
            background: linear-gradient(135deg, rgba(102,126,234,0.08), rgba(118,75,162,0.08));
            color: #333;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: none;
        }

        @if (temaOscuro)
        {
            <text>
            body { background-color: #1a1a2e !important; color: #e0e0e0 !important; }
            .card { background: #16213e !important; color: #e0e0e0 !important; }
            .card-body { color: #e0e0e0; }
            .table { color: #e0e0e0; }
            .form-control, .form-select { background: #1a1a2e; color: #e0e0e0; border-color: #333; }
            </text>
        }
    </style>

    @RenderSection("Head", required: false)
</head>
<body>

    <!-- NAVBAR PRINCIPAL -->
    <nav class="navbar navbar-expand-lg fs-navbar">
        <div class="container-fluid">
            <!-- Brand -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                @if (!string.IsNullOrEmpty(config.RutaLogo))
                {
                    <img src="@config.RutaLogo" alt="Logo" />
                }
                else
                {
                    <i class="fas fa-shopping-bag"></i>
                }
                @(config.NombreTienda ?? "FashionStore")
            </a>

            <!-- Toggler mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <!-- Menú izquierdo -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Index" onclick="window.location.href='/Home/Index'; return false;">
                            <i class="fas fa-home me-1"></i>Inicio
                        </a>
                    </li>

                    @if (User?.IsInRole("Administrador") ?? false)
                    {
                        <!-- Catálogo -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-tshirt me-1"></i>Catálogo
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Prendas" asp-action="Index"><i class="fas fa-tshirt me-2 text-primary"></i>Prendas</a></li>
                                <li><a class="dropdown-item" asp-controller="Categorias" asp-action="Index"><i class="fas fa-tags me-2 text-success"></i>Categorías</a></li>
                            </ul>
                        </li>

                        <!-- Admin -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-users-cog me-1"></i>Admin
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Clientes" asp-action="Index"><i class="fas fa-users me-2 text-info"></i>Clientes</a></li>
                                <li><a class="dropdown-item" asp-controller="Vendedores" asp-action="Index"><i class="fas fa-user-tie me-2 text-warning"></i>Vendedores</a></li>
                                <li><a class="dropdown-item" asp-controller="Descuentos" asp-action="Index"><i class="fas fa-percent me-2 text-danger"></i>Descuentos</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Reportes" asp-action="Index"><i class="fas fa-chart-bar me-2 text-primary"></i>Reportes</a></li>
                                <li><a class="dropdown-item" asp-controller="Configuracion" asp-action="Index"><i class="fas fa-cogs me-2 text-secondary"></i>Configuración</a></li>
                            </ul>
                        </li>

                        <!-- Ventas -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-cash-register me-1"></i>Ventas
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Ventas" asp-action="Create"><i class="fas fa-plus-circle me-2 text-success"></i>Nueva Venta (POS)</a></li>
                                <li><a class="dropdown-item" asp-controller="Ventas" asp-action="Index"><i class="fas fa-list me-2 text-primary"></i>Historial de Ventas</a></li>
                            </ul>
                        </li>
                    }

                    @if ((User?.IsInRole("Vendedor") ?? false) && !(User?.IsInRole("Administrador") ?? false))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-cash-register me-1"></i>Ventas
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Ventas" asp-action="Create"><i class="fas fa-plus-circle me-2 text-success"></i>Nueva Venta (POS)</a></li>
                                <li><a class="dropdown-item" asp-controller="Ventas" asp-action="Index"><i class="fas fa-list me-2 text-primary"></i>Mis Ventas</a></li>
                            </ul>
                        </li>
                    }
                </ul>

                <!-- Menú derecho -->
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User?.IsInRole("Administrador") ?? false)
                    {
                        <li class="nav-item me-2">
                            <span class="badge bg-danger badge-role px-3 py-2">
                                <i class="fas fa-shield-alt me-1"></i>Admin
                            </span>
                        </li>
                    }
                    else if (User?.IsInRole("Vendedor") ?? false)
                    {
                        <li class="nav-item me-2">
                            <span class="badge bg-success badge-role px-3 py-2">
                                <i class="fas fa-user-check me-1"></i>Vendedor
                            </span>
                        </li>
                    }

                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" data-bs-toggle="dropdown">
                                <div style="width:32px;height:32px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                    <i class="fas fa-user" style="color:white;font-size:0.85rem;"></i>
                                </div>
                                <span style="color:white;font-size:0.875rem;">@(User.Identity?.Name?.Split('@')[0] ?? "Usuario")</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <div class="px-3 py-2 border-bottom">
                                        <div class="fw-bold small">@(User.Identity?.Name ?? "-")</div>
                                        @if (User?.IsInRole("Administrador") ?? false)
                                        {
                                            <span class="badge bg-danger" style="font-size:0.7rem;">Administrador</span>
                                        }
                                        else if (User?.IsInRole("Vendedor") ?? false)
                                        {
                                            <span class="badge bg-success" style="font-size:0.7rem;">Vendedor</span>
                                        }
                                    </div>
                                </li>
                                <li><a class="dropdown-item" href="/Perfil"><i class="fas fa-user-cog me-2 text-muted"></i>Mi Perfil</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="#" onclick="document.getElementById('logoutForm').submit(); return false;">
                                        <i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <form id="logoutForm" action="/Identity/Account/Logout?returnUrl=%2F" method="post" style="display:none;">
                            @Html.AntiForgeryToken()
                        </form>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Identity/Account/Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Login
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- /.navbar -->

    <!-- Content Wrapper -->
    <div class="fs-content">


        @RenderBody()
    </div>
    <!-- /.content -->

    <!-- Footer -->
    <footer class="fs-footer">
        <strong>@Html.Raw(config.TextoPiePagina ?? $"&copy; {DateTime.Now.Year} {config.NombreTienda ?? "FashionStore"}. Todos los derechos reservados.")</strong>
        @if (!string.IsNullOrEmpty(config.Telefono))
        {
            <span class="ms-3"><i class="fas fa-phone me-1"></i>@config.Telefono</span>
        }
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

    <!-- Toastr -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <!-- Temas Manager -->
    <script src="~/js/temas.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>