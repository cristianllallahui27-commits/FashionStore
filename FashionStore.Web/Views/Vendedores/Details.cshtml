@model FashionStore.Domain.Entities.Vendedor

@{
    ViewData["Title"] = "Detalle de Vendedor";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container py-4" style="max-width:700px;">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h1 class="fw-bold mb-0 text-primary fs-3">
            <i class="fas fa-user me-2"></i>@Model.Nombres @Model.Apellidos
        </h1>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">NOMBRES</label>
                        <p class="fs-5">@Model.Nombres</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">APELLIDOS</label>
                        <p class="fs-5">@Model.Apellidos</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">DNI</label>
                        <p class="fs-5 font-monospace">@Model.DNI</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">TELÉFONO</label>
                        <p class="fs-5">@(string.IsNullOrEmpty(Model.Telefono) ? "No especificado" : Model.Telefono)</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">CORREO</label>
                        <p class="fs-5">@(string.IsNullOrEmpty(Model.Correo) ? "No especificado" : Model.Correo)</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">ESTADO</label>
                        <p class="fs-5">
                            @if (Model.Estado)
                            {
                                <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="fas fa-times-circle me-1"></i>Inactivo</span>
                            }
                        </p>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="fas fa-edit me-1"></i>Editar
                </a>
            </div>
        </div>
    </div>
</div>

