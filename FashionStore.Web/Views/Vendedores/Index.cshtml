@model IList<FashionStore.Domain.Entities.Vendedor>

@{
    ViewData["Title"] = "Gestión de Vendedores";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-muted mb-0">Administra los vendedores del sistema y sus accesos</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Nuevo Vendedor
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (User.IsInRole("Administrador"))
    {
        <div class="alert alert-warning border-start border-warning border-4 py-2 small mb-3" role="alert">
            <i class="fas fa-lock me-2"></i>
            <strong>Área protegida:</strong> La columna de contraseñas solo es visible para el Administrador.
            Haz clic en el <i class="fas fa-eye ms-1 me-1"></i> para revelar la contraseña de cada vendedor.
        </div>
    }

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Nombre Completo</th>
                            <th>DNI</th>
                            <th>Teléfono</th>
                            <th>Correo / Usuario</th>
                            @if (User.IsInRole("Administrador"))
                            {
                                <th class="text-center">Contraseña</th>
                            }
                            <th class="text-center">Estado</th>
                            <th class="pe-4 text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="@(User.IsInRole("Administrador") ? 8 : 7)" class="text-center p-5 text-muted">
                                    <i class="fas fa-user-tie fa-3x mb-3 d-block opacity-25"></i>
                                    No hay vendedores registrados.
                                    <a asp-action="Create" class="d-block mt-2">Crear el primero</a>
                                </td>
                            </tr>
                        }
                        @foreach (var v in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@v.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold"
                                             style="width:38px;height:38px;font-size:0.95rem;background:var(--fs-gradient)!important;">
                                            @v.Nombres.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@v.Nombres @v.Apellidos</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="font-monospace">@v.DNI</td>
                                <td>@(v.Telefono ?? "-")</td>
                                <td class="text-muted small">@(v.Correo ?? "-")</td>

                                @if (User.IsInRole("Administrador"))
                                {
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(v.UltimaPasswordAdmin))
                                        {
                                            <div class="d-flex align-items-center justify-content-center gap-2">
                                                <span class="font-monospace pwd-mask-@v.Id" style="letter-spacing:2px;">••••••••</span>
                                                <span class="font-monospace pwd-text-@v.Id d-none text-danger fw-bold">@v.UltimaPasswordAdmin</span>
                                                <button type="button" class="btn btn-link p-0 ms-1"
                                                        onclick="togglePwdRow(@v.Id)"
                                                        title="Ver/Ocultar contraseña">
                                                    <i class="fas fa-eye text-muted" id="eye-@v.Id"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-secondary border small">No asignada</span>
                                        }
                                    </td>
                                }

                                <td class="text-center">
                                    @if (v.Estado)
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check me-1"></i>Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="fas fa-ban me-1"></i>Inactivo</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="ToggleEstado" asp-route-id="@v.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(v.Estado ? "btn-outline-warning" : "btn-outline-success")"
                                                title="@(v.Estado ? "Desactivar" : "Activar")">
                                            <i class="fas @(v.Estado ? "fa-ban" : "fa-check")"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePwdRow(id) {
    const mask = document.querySelector(`.pwd-mask-${id}`);
    const text = document.querySelector(`.pwd-text-${id}`);
    const eye  = document.getElementById(`eye-${id}`);

    if (mask && text && eye) {
        if (mask.classList.contains('d-none')) {
            mask.classList.remove('d-none');
            text.classList.add('d-none');
            eye.classList.replace('fa-eye-slash', 'fa-eye');
        } else {
            mask.classList.add('d-none');
            text.classList.remove('d-none');
            eye.classList.replace('fa-eye', 'fa-eye-slash');
        }
    }
}
</script>
}
