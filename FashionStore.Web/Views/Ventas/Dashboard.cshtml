@model FashionStore.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard Ventas";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

    body {
        background: linear-gradient(rgba(0,0,0,.85), rgba(0,0,0,.85)), url('https://images.unsplash.com/photo-1556740749-887f6717d7e4');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
    }

    .glass {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(12px);
        border-radius: 25px;
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
    }

    .card-modern {
        border: none;
        border-radius: 20px;
        transition: .3s;
    }

        .card-modern:hover {
            transform: translateY(-5px);
        }

    .title-dashboard {
        font-size: 40px;
        font-weight: bold;
    }

</style>

<div class="container py-5">

    <div class="glass p-5 shadow-lg">

        <!-- HEADER -->

        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>

                <h1 class="title-dashboard">

                    <i class="bi bi-cash-stack"></i>

                    Dashboard Ventas

                </h1>

                <p class="text-light">

                    Estad�sticas reales desde SQL Server

                </p>

            </div>

            <div>

                <a asp-controller="Ventas"
                   asp-action="Index"
                   class="btn btn-light btn-lg">

                    <i class="bi bi-list"></i>

                    Ver Ventas

                </a>

                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light ms-3 btn-lg">

                    <i class="bi bi-house"></i>

                    Inicio

                </a>

            </div>

        </div>

        <!-- TARJETAS -->

        <div class="row g-4">

            <!-- TOTAL VENTAS -->

            <div class="col-md-4">

                <div class="card bg-success text-white p-4 shadow card-modern">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h5>Total Ventas</h5>

                            <h1>@Model.TotalVentas</h1>

                        </div>

                        <i class="bi bi-cart-check-fill"
                           style="font-size:60px;"></i>

                    </div>

                </div>

            </div>

            <!-- CLIENTES -->

            <div class="col-md-4">

                <div class="card bg-primary text-white p-4 shadow card-modern">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h5>Clientes</h5>

                            <h1>@Model.TotalClientes</h1>

                        </div>

                        <i class="bi bi-people-fill"
                           style="font-size:60px;"></i>

                    </div>

                </div>

            </div>

            <!-- INGRESOS -->

            <div class="col-md-4">

                <div class="card bg-danger text-white p-4 shadow card-modern">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h5>Ingresos</h5>

                            <h1>S/ @Model.TotalIngresos</h1>

                        </div>

                        <i class="bi bi-currency-dollar"
                           style="font-size:60px;"></i>

                    </div>

                </div>

            </div>

        </div>

        <!-- GRAFICOS -->

        <div class="row mt-5 g-4">

            <!-- VENTAS MENSUALES -->

            <div class="col-md-8">

                <div class="card bg-dark p-4 shadow-lg">

                    <h3 class="text-white mb-4">

                        <i class="bi bi-graph-up-arrow"></i>

                        Ingresos mensuales

                    </h3>

                    <canvas id="ventasChart"></canvas>

                </div>

            </div>

            <!-- CATEGORIAS -->

            <div class="col-md-4">

                <div class="card bg-dark p-4 shadow-lg">

                    <h3 class="text-white mb-4">

                        <i class="bi bi-pie-chart-fill"></i>

                        Ventas por categor�a

                    </h3>

                    <canvas id="categoriasChart"></canvas>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

    // =====================================
    // GRAFICO VENTAS
    // =====================================

    const ventasCtx =
        document.getElementById('ventasChart');

    new Chart(ventasCtx, {

        type: 'line',

        data: {

            labels:
            @Html.Raw(Model.SalesChartLabelsJson ?? "[]"),

            datasets: [{

                label: 'Ingresos reales',

                data:
                @Html.Raw(Model.SalesChartDataJson ?? "[]"),

                borderColor: '#00ff99',

                backgroundColor: 'rgba(0,255,153,.15)',

                fill: true,

                tension: .4,

                borderWidth: 4,

                pointRadius: 5
            }]
        },

        options: {

            responsive: true,

            plugins: {

                legend: {

                    labels: {

                        color: 'white'
                    }
                }
            },

            scales: {

                x: {

                    ticks: {

                        color: 'white'
                    }
                },

                y: {

                    ticks: {

                        color: 'white'
                    },

                    beginAtZero: true
                }
            }
        }
    });

    // =====================================
    // GRAFICO CATEGORIAS
    // =====================================

    const catCtx =
        document.getElementById('categoriasChart');

    new Chart(catCtx, {

        type: 'doughnut',

        data: {

            labels:
            @Html.Raw(Model.PrendasByCategoryLabelsJson ?? "[]"),

            datasets: [{

                data:
                @Html.Raw(Model.PrendasByCategoryDataJson ?? "[]"),

                backgroundColor: [

                    '#0d6efd',
                    '#198754',
                    '#dc3545',
                    '#ffc107',
                    '#6f42c1',
                    '#20c997'

                ]
            }]
        }
    });

</script>