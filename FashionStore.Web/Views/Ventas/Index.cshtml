@model FashionStore.Web.ViewModels.VentasIndexViewModel

@{
    ViewData["Title"] = "Gestión de Ventas";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<!-- Header -->
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1 text-primary"><i class="fas fa-receipt me-2"></i>Gestión de Ventas</h1>
            <p class="text-muted mb-0">Administra todas las transacciones de venta de la tienda</p>
        </div>
        <div>
            <a asp-action="ExportarExcel" class="btn btn-success btn-lg shadow-sm me-2">
                <i class="fas fa-file-excel me-2"></i>Exportar Excel
            </a>
            <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
                <i class="fas fa-plus me-2"></i>Nueva Venta (POS)
            </a>
        </div>
    </div>
</div>


<!-- Resumen Rápido -->
<div class="row mb-5">
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm bg-gradient-primary text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="card-body">
                <p class="small text-white-50 mb-1">Ventas Hoy</p>
                <h3 class="fw-bold mb-0">@Model.VentasHoy</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm bg-gradient-success text-white" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
            <div class="card-body">
                <p class="small text-white-50 mb-1">Ingresos Hoy</p>
                <h3 class="fw-bold mb-0">S/. @Model.IngresosHoy.ToString("F2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <p class="text-muted small mb-1">Total Ventas</p>
                <h3 class="text-dark fw-bold mb-0">@Model.TotalVentas</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <p class="text-muted small mb-1">Ingresos Totales</p>
                <h3 class="text-dark fw-bold mb-0">S/. @Model.IngresosTotal.ToString("F2")</h3>
            </div>
        </div>
    </div>
</div>

<!-- Búsqueda y Filtros -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" class="form-control border-start-0" id="searchVentas" placeholder="Buscar por ID, cliente o vendedor...">
                </div>
            </div>
            <div class="col-md-6">
                <input type="date" class="form-control" id="filterFecha">
            </div>
        </div>
    </div>
</div>

<!-- Tabla de Ventas -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="tablasVentas">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID Venta</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Método Pago</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th class="pe-4 text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Ventas != null && Model.Ventas.Any())
                    {
                        foreach (var venta in Model.Ventas)
                        {
                            <tr class="venta-row" data-id="@venta.Id" data-cliente="@(venta.Cliente?.NombreCompleto ?? "")" data-fecha="@venta.Fecha.ToString("yyyy-MM-dd")">
                                <td class="ps-4 fw-bold text-primary">#@venta.Id.ToString("D4")</td>
                                <td>
                                    <div class="fw-semibold">@(venta.Cliente?.NombreCompleto ?? "Público General")</div>
                                    <small class="text-muted">DNI: @(venta.Cliente?.DNI ?? "-")</small>
                                </td>
                                <td>@venta.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="fas fa-credit-card me-1"></i>@(venta.MetodoPago?.Nombre ?? "Efectivo")
                                    </span>
                                </td>
                                <td class="fw-bold text-dark">S/. @venta.Total.ToString("F2")</td>
                                <td><span class="badge bg-success">Completado</span></td>
                                <td class="pe-4 text-end">
                                    <a asp-action="Details" asp-route-id="@venta.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye me-1"></i>Ver Detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center p-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                <p class="text-muted mb-0">No hay ventas registradas en el sistema</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('searchVentas');
            const fechaInput = document.getElementById('filterFecha');
            const rows = document.querySelectorAll('.venta-row');

            function filterTable() {
                const query = searchInput.value.toLowerCase().trim();
                const selectedDate = fechaInput.value; // YYYY-MM-DD

                rows.forEach(row => {
                    const id = row.getAttribute('data-id').toLowerCase();
                    const cliente = row.getAttribute('data-cliente').toLowerCase();
                    const fecha = row.getAttribute('data-fecha'); // YYYY-MM-DD

                    const matchesSearch = id.includes(query) || cliente.includes(query);
                    const matchesDate = !selectedDate || fecha === selectedDate;

                    if (matchesSearch && matchesDate) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }

            searchInput.addEventListener('input', filterTable);
            fechaInput.addEventListener('change', filterTable);
        });
    </script>
}
